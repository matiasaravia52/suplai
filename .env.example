# Supabase — copiar a .env.local y completar con los valores reales
# Local: obtener con `supabase status` después de `supabase start`
# Producción: obtener desde el dashboard de Supabase

NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Dominio base de la app (sin protocolo)
# Local: localhost
# Producción: suplai.app
NEXT_PUBLIC_APP_DOMAIN=localhost
